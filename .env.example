# Firebase — project: nexuswire-app
# https://console.firebase.google.com/project/nexuswire-app

# Client (Firebase Console → Project settings → Your apps → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=nexuswire-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=nexuswire-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=nexuswire-app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server (Firebase Console → Project settings → Service accounts → Generate new private key)
FIREBASE_PROJECT_ID=nexuswire-app
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# GitHub (optional, for CI deploy)
# GITHUB_REPOSITORY=dnkefua/nexuswire
