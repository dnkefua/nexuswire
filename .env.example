# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=NexusWire
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Firebase Client (Console → Project settings → Your apps → Web app) ──────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=nexuswire-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=nexuswire-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=nexuswire-app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (Console → Service accounts → Generate new private key) ──
FIREBASE_PROJECT_ID=nexuswire-app
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Google Discovery Layer (optional — discovery degrades gracefully) ───────
# Programmable Search Engine restricted to trusted African publisher domains
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# YouTube Data API v3 (falls back to channel RSS when unset)
YOUTUBE_API_KEY=

# ─── AI Enrichment (optional — summaries are skipped when unset) ─────────────
GEMINI_API_KEY=
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=

# ─── Ingestion & Admin ───────────────────────────────────────────────────────
# Secret for protected ingestion endpoints (cron). Also accepted: CRON_SECRET.
NEWS_INGEST_SECRET=
CRON_SECRET=
ADMIN_EMAILS=

# ─── Demo mode ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_DEMO_FALLBACKS=false
